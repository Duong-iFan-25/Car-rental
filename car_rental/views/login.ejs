<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Đăng nhập hệ thống</title>
</head>
<body>
    <h2>ĐĂNG NHẬP THUÊ XE</h2>
    
    <% if(error) { %>
        <p style="color: red;"><%= error %></p>
    <% } %>

    <form action="/auth/login" method="POST">
        <label>Tài khoản:</label><br>
        <input type="text" name="username" required placeholder="Nhập: sinhvien"><br><br>
        
        <label>Mật khẩu:</label><br>
        <input type="password" name="password" required placeholder="Nhập: 123"><br><br>
        
        <button type="submit">Đăng nhập</button>
    </form>
    <p><i>Mẹo test: Tài khoản là "sinhvien" / Mật khẩu là "123"</i></p>
</body>
</html>