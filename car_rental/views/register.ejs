<%- include("layouts/header") %>

<h1>Đăng ký</h1>

<%# Nếu controller truyền lỗi sang thì hiển thị tại đây. %>
<% if (error) { %>
<p class="alert"><%= error %></p>
<% } %>

<%# formData giúp giữ lại họ tên, username và số điện thoại khi nhập sai. %>
<form class="form" action="/register" method="post">
  <label>Họ tên</label>
  <input type="text" name="full_name" maxlength="100" value="<%= formData.full_name %>" required>

  <label>Tên tài khoản</label>
  <input type="text" name="username" maxlength="100" value="<%= formData.username %>" required>

  <label>Mật khẩu</label>
  <input type="password" name="password" required>

  <label>Nhập lại mật khẩu</label>
  <input type="password" name="confirm_password" required>

  <label>Số điện thoại</label>
  <input type="text" name="phone" maxlength="20" value="<%= formData.phone %>">

  <button class="btn btn-primary" type="submit">Đăng ký</button>
</form>

<p>Đã có tài khoản? <a href="/login">Đăng nhập</a></p>

<%- include("layouts/footer") %>
