<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng ký tài khoản mới</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        /* CSS riêng biệt dành cho trang Login/Register để căn giữa màn hình */
        .auth-wrapper {
            min-height: 90vh;
            display: table;
            width: 100%;
        }
        .auth-cell {
            display: table-cell;
            vertical-align: middle;
            text-align: center;
        }
        .auth-card {
            display: inline-block;
            width: 100%;
            max-width: 420px;
            background: white;
            padding: 35px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            border: 1px solid #e2e8f0;
            text-align: left;
        }
        .auth-card h2 {
            font-size: 24px;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 8px;
            text-align: center;
        }
        .auth-card p.subtitle {
            font-size: 14px;
            color: #64748b;
            margin-bottom: 25px;
            text-align: center;
        }
        .form-group {
            margin-bottom: 18px;
        }
        .form-group label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            color: #475569;
            margin-bottom: 6px;
        }
        .form-group input {
            width: 100%;
            padding: 10px 14px;
            font-size: 15px;
            border: 1px solid #cbd5e1;
            border-radius: 6px;
            outline: none;
            transition: border-color 0.2s;
        }
        .form-group input:focus {
            border-color: #2b6cb0;
        }
        .btn-auth-submit {
            width: 100%;
            background-color: #2b6cb0;
            color: white;
            border: none;
            padding: 12px;
            font-size: 16px;
            font-weight: 600;
            border-radius: 6px;
            cursor: pointer;
            margin-top: 10px;
            transition: background 0.2s;
        }
        .btn-auth-submit:hover {
            background-color: #1d4ed8;
        }
        .auth-footer {
            margin-top: 20px;
            text-align: center;
            font-size: 14px;
            color: #64748b;
        }
        .auth-footer a {
            color: #2b6cb0;
            text-decoration: none;
            font-weight: 600;
        }
        .alert {
            padding: 10px 12px;
            border-radius: 6px;
            font-size: 14px;
            margin-bottom: 15px;
        }
        .alert-error {
            background-color: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
        }
        .alert-success {
            background-color: #dcfce7;
            color: #166534;
            border: 1px solid #86efac;
        }
    </style>
</head>
<body>

    <header>
        <div class="navbar">
            <a href="/cars" class="nav-logo">🚗 PHENIKAA CARS</a>
            <div class="nav-links">
                <a href="/auth/login" class="btn-login">Đăng nhập</a>
            </div>
        </div>
    </header>

    <div class="auth-wrapper">
        <div class="auth-cell">
            <div class="auth-card">
                <h2>Tạo tài khoản mới</h2>
                <p class="subtitle">Vui lòng điền thông tin bên dưới để đăng ký</p>

                <% if (error) { %>
                    <div class="alert alert-error"><%= error %></div>
                <% } %>
                <% if (success) { %>
                    <div class="alert alert-success"><%= success %></div>
                <% } %>

                <form action="/auth/register" method="POST">
                    <div class="form-group">
                        <label for="fullName">Họ và tên của bạn</label>
                        <input type="text" id="fullName" name="fullName" placeholder="Ví dụ: Nguyễn Văn A" required>
                    </div>

                    <div class="form-group">
                        <label for="username">Tên tài khoản (Username)</label>
                        <input type="text" id="username" name="username" placeholder="Nhập tên tài khoản..." required>
                    </div>

                    <div class="form-group">
                        <label for="password">Mật khẩu</label>
                        <input type="password" id="password" name="password" placeholder="Tối thiểu 6 ký tự..." required>
                    </div>

                    <button type="submit" class="btn-auth-submit">Đăng ký ngay</button>
                </form>

                <div class="auth-footer">
                    Bạn đã có tài khoản? <a href="/auth/login">Đăng nhập ngay</a>
                </div>
            </div>
        </div>
    </div>

</body>
</html>