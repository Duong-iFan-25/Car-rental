<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Chi tiết xe <%= car.name %></title>
</head>
<body>
    <a href="/cars"><- Quay lại danh sách</a>
    <h1>Thông tin chi tiết: <%= car.name %></h1>
    <p>Hãng sản xuất: <%= car.brand %></p>
    <p>Truyền động: <%= car.type %></p>
    <p>Giá thuê: <b style="color: green;"><%= car.pricePerDay.toLocaleString() %> VNĐ/ngày</b></p>
    
    <hr>
    
    <h3>TIẾN HÀNH ĐẶT XE</h3>
    <% if (user) { %>
        <p>Xin chào <b><%= user.fullName %></b>, vui lòng chọn thời gian mượn xe:</p>
        <form action="/cars/<%= car.id %>/book" method="POST">
            <label>Ngày nhận xe:</label>
            <input type="date" name="startDate" required>
            
            <label>Ngày trả xe:</label>
            <input type="date" name="endDate" required>
            <br><br>
            <button type="submit" style="background: green; color: white; padding: 10px 20px; border: none; cursor: pointer;">
                Xác nhận đặt xe ngay
            </button>
        </form>
    <% } else { %>
        <p style="color: orange;">Bạn cần <a href="/auth/login">Đăng nhập</a> để thực hiện đặt chiếc xe này.</p>
    <% } %>
</body>
</html>