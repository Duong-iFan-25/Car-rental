<%- include("layouts/header") %>

<%# Biến car được carController truyền sang khi gọi res.render. %>
<h1><%= car.name %></h1>

<div class="detail-box">
    <img src="<%= getCarImage(car.image) %>" alt="<%= car.name %>">
    <div>
        <p>Hãng: <%= car.brand %></p>
        <p>Loại xe: <%= car.car_type %></p>
        <p>Số chỗ: <%= car.seats %></p>
        <p>Giá thuê: <strong><%= formatCurrency(car.price_per_day) %>/ngày</strong></p>
        <p>Mô tả: <%= car.description %></p>
    </div>
</div>

<%# Chỉ hiện form đặt xe khi session đã có người dùng đăng nhập. %>
<% if (user) { %>
    <h2>Đặt xe</h2>
    <form class="form" action="/bookings/create/<%= car.id %>" method="post">
        <label>Ngày bắt đầu</label>
        <input type="date" name="start_date" required>

        <label>Ngày kết thúc</label>
        <input type="date" name="end_date" required>

        <label>Ghi chú</label>
        <textarea name="note" rows="3"></textarea>

        <button class="btn btn-primary" type="submit">Đặt xe</button>
    </form>
<% } else { %>
    <p><a href="/login">Đăng nhập</a> để đặt xe.</p>
<% } %>

<%- include("layouts/footer") %>
