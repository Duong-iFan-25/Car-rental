<%- include("layouts/header") %>

<h1>Đơn đặt xe của tôi</h1>

<%# Mỗi phần tử trong bookings sẽ được hiển thị thành một dòng. %>
<table>
    <thead>
        <tr>
            <th>Xe</th>
            <th>Ngày thuê</th>
            <th>Ngày trả</th>
            <th>Tổng tiền</th>
            <th>Ghi chú</th>
        </tr>
    </thead>
    <tbody>
        <% bookings.forEach(function(booking) { %>
            <tr>
                <td><%= booking.car_name || "Xe đã xóa" %></td>
                <td><%= formatDate(booking.start_date) %></td>
                <td><%= formatDate(booking.end_date) %></td>
                <td><%= formatCurrency(booking.total_price) %></td>
                <td><%= booking.note || "" %></td>
            </tr>
        <% }) %>
    </tbody>
</table>

<%# Hiển thị lời nhắc khi người dùng chưa đặt xe. %>
<% if (bookings.length === 0) { %>
    <p>Bạn chưa có đơn đặt xe nào.</p>
<% } %>

<%- include("layouts/footer") %>
